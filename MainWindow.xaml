<Window x:Class="kr2pks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сетевых подключений" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Анализатор сетевых подключений" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" 
                   Margin="0,0,0,10"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Сетевые интерфейсы" 
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                
                <ListBox Grid.Row="1" x:Name="InterfacesListBox" 
                         SelectionChanged="InterfacesListBox_SelectionChanged"
                         DisplayMemberPath="Name"/>
            </Grid>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" 
                          Background="LightGray" Width="2"/>
            
            <ScrollViewer Grid.Column="2" Margin="5">
                <StackPanel>
                    <GroupBox Header="Информация о выбранном интерфейсе" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP-адрес:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="IpAddressText" Margin="5"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Маска подсети:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SubnetMaskText" Margin="5"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="MAC-адрес:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="MacAddressText" Margin="5"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Состояние:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="StatusText" Margin="5"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Скорость:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="SpeedText" Margin="5"/>
                            
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Тип:" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TypeText" Margin="5"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Анализ URL/URI" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="UrlTextBox" Width="300" Margin="0,0,5,0"/>
                                <Button x:Name="AnalyzeButton" Content="Анализировать" 
                                        Click="AnalyzeButton_Click" Padding="10,5"/>
                            </StackPanel>
                            
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Схема:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SchemeText" Margin="5"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HostText" Margin="5"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PortText" Margin="5"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Путь:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PathText" Margin="5"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Параметры:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="QueryText" Margin="5"/>
                                
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Фрагмент:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="FragmentText" Margin="5"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Дополнительные функции" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <Button x:Name="PingButton" Content="Проверить доступность (Ping)" 
                                        Click="PingButton_Click" Padding="10,5" Margin="0,0,5,0"/>
                                <Button x:Name="DnsButton" Content="Получить DNS информацию" 
                                        Click="DnsButton_Click" Padding="10,5"/>
                            </StackPanel>
                            <TextBlock x:Name="PingResultText" Margin="5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="История проверенных URL">
                        <ListBox x:Name="HistoryListBox" Height="150" 
                                 SelectionChanged="HistoryListBox_SelectionChanged"/>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Готов"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>